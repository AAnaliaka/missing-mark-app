<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    tools:context=".PrivacyPolicyActivity">

    <View
        android:id="@+id/topHeader"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="@drawable/btn_gradient"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/backBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:padding="8dp"
        android:text="← Back"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/topHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Privacy Notice"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/topHeader"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/topHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Privacy Notice"
                android:textColor="@color/primary_dark"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Last Updated: May 18, 2026"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="This Privacy Notice describes how we collect and use your personal information in relation to MissingMarks APP websites, applications, products, services, events, and experiences that reference this Privacy Notice (together, “MissingMarks APP Offerings”). MissingMarks APP operates under the flag of Ryvo Limited."
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.2" />

            <LinearLayout
                android:id="@+id/toc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp">
                <!-- TOC Links will be styled here -->
            </LinearLayout>

            <TextView
                android:id="@+id/section1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Personal Information We Collect"
                android:textColor="@color/primary_dark"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp" />
            <TextView
                android:id="@+id/text1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/section2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="How We Use Personal Information"
                android:textColor="@color/primary_dark"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp" />
            <TextView
                android:id="@+id/text2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/section3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cookies"
                android:textColor="@color/primary_dark"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp" />
            <TextView
                android:id="@+id/text3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/section4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="How We Share Personal Information"
                android:textColor="@color/primary_dark"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp" />
            <TextView
                android:id="@+id/text4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/section5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Location of Personal Information"
                android:textColor="@color/primary_dark"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp" />
            <TextView
                android:id="@+id/text5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/section6"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="How We Secure Information"
                android:textColor="@color/primary_dark"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp" />
            <TextView
                android:id="@+id/text6"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/section7"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Advertising"
                android:textColor="@color/primary_dark"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp" />
            <TextView
                android:id="@+id/text7"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/section8"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Access and Choice"
                android:textColor="@color/primary_dark"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp" />
            <TextView
                android:id="@+id/text8"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/section9"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Children’s Personal Information"
                android:textColor="@color/primary_dark"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp" />
            <TextView
                android:id="@+id/text9"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/section10"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Third Party Sites and Services"
                android:textColor="@color/primary_dark"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp" />
            <TextView
                android:id="@+id/text10"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/section11"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Retention of Personal Information"
                android:textColor="@color/primary_dark"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp" />
            <TextView
                android:id="@+id/text11"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/section12"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Contacts, Notices, and Revisions"
                android:textColor="@color/primary_dark"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp" />
            <TextView
                android:id="@+id/text12"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/section13"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Additional Information for Certain Jurisdictions (Kenya)"
                android:textColor="@color/primary_dark"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp" />
            <TextView
                android:id="@+id/text13"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/section14"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Examples of Information Collected"
                android:textColor="@color/primary_dark"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp" />
            <TextView
                android:id="@+id/text14"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="40dp"
                android:text="© 2026 Ryvo Limited. All rights reserved."
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:gravity="center" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>